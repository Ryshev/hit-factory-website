RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Auto-detect language from Accept-Language header (only for root /)
# Only redirect if no locale cookie is set (user hasn't chosen manually)
RewriteCond %{REQUEST_URI} ^/$
RewriteCond %{HTTP:Accept-Language} ^ru [NC]
RewriteCond %{HTTP_COOKIE} !hf-locale=
RewriteRule ^$ /ru/ [R=302,L]

RewriteCond %{REQUEST_URI} ^/$
RewriteCond %{HTTP:Accept-Language} ^uk [NC]
RewriteCond %{HTTP_COOKIE} !hf-locale=
RewriteRule ^$ /uk/ [R=302,L]

RewriteCond %{REQUEST_URI} ^/$
RewriteCond %{HTTP:Accept-Language} ^ka [NC]
RewriteCond %{HTTP_COOKIE} !hf-locale=
RewriteRule ^$ /ka/ [R=302,L]

RewriteCond %{REQUEST_URI} ^/$
RewriteCond %{HTTP:Accept-Language} ^hy [NC]
RewriteCond %{HTTP_COOKIE} !hf-locale=
RewriteRule ^$ /hy/ [R=302,L]

RewriteCond %{REQUEST_URI} ^/$
RewriteCond %{HTTP:Accept-Language} ^kk [NC]
RewriteCond %{HTTP_COOKIE} !hf-locale=
RewriteRule ^$ /kk/ [R=302,L]

# Security: block admin data files
RewriteRule ^admin/data/ - [F,L]

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
